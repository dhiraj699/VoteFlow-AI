# Frontend Environment Variables
# Copy this file to .env.local and fill in your actual credentials

# Backend API Configuration
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_API_URL_PROD=https://your-backend-api-domain.com

# Firebase Configuration (for frontend)
# Get from Firebase Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Google Gemini API (optional frontend usage)
NEXT_PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# Application Settings
NEXT_PUBLIC_APP_NAME=VoteFlow-AI
NEXT_PUBLIC_APP_DESCRIPTION=Electoral Awareness Platform
